{
  "name": "indian-market-ai-agent-backend",
  "version": "1.0.0",
  "description": "Production-grade Indian Market AI Trading Agent Backend",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "build": "node --check src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage",
    "lint": "eslint src/",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "docker:build": "docker build -t indian-market-ai-agent .",
